formatter = pkgs.writeShellScriptBin "nixfmt-wrapper" ''
  set -euo pipefail
  if [ "$#" -gt 0 ]; then
    mapfile -t files < <(
      ${pkgs.git}/bin/git ls-files -- "$@" \
        | ${pkgs.gnugrep}/bin/grep -E '\.nix$' \
        || true
    )
  else
    mapfile -t files < <(${pkgs.git}/bin/git ls-files '*.nix')
  fi
  if [ "''${#files[@]}" -eq 0 ]; then
    exit 0
  fi
  exec ${pkgs.nixfmt}/bin/nixfmt "''${files[@]}"
'';
