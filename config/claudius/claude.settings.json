      "Bash(pytest:*)",
      "Bash(python:*)",
      "Bash(rg:*)",
      "Bash(rye:*)",
      "Bash(rust-analyzer:*)",
      "Bash(rustc:*)",
      "Bash(rustup:*)",
      "Bash(sbt:*)",
      "Bash(sed:*)",
      "Bash(shellcheck:*)",
      "Bash(sqlc:*)",
      "Bash(tar:*)",
      "Bash(terraform plan:*)",
