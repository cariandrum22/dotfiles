      "Bash(terragrunt apply:*)",
      "Bash(tofu apply:*)",
      "Bash(cargo publish:*)",
      "Bash(npm publish:*)",
      "LS(!~/.ssh/config)",
      "LS(~/.ssh/**)",
      "Read(!~/.ssh/config)",
      "Read(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Edit(~/.ssh/**)",
      "Read(/etc/passwd)",
      "Read(/etc/shadow)",
      "Read(/etc/group)",
      "Read(/etc/gshadow)",
      "Read(/etc/sudoers)",
      "Read(/etc/sudoers.d/**)",
      "Write(/etc/passwd)",
      "Write(/etc/shadow)",
      "Write(/etc/group)",
      "Write(/etc/gshadow)",
      "Write(/etc/sudoers)",
      "Write(/etc/sudoers.d/**)",
