      "Bash(zig:*)",
      "WebFetch(domain:*)",
      "mcp__awslabs_aws-documentation-mcp-server",
      "mcp__codex",
      "mcp__figma",
      "mcp__chrome-devtools",
      "mcp__github",
      "mcp__google-calendar",
      "mcp__perplexity-ask",
      "mcp__playwright",
      "mcp__todoist"
