    "deny": [
      "Bash(sudo: --login:*)",
      "Bash(sudo -i:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /home/*)",
      "Bash(rm -rf /root)",
      "Bash(chown:*)",
