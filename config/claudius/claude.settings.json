      "Bash(chattr:*)",
      "Bash(docker system prune:*)",
      "Bash(docker push:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl replace:*)",
