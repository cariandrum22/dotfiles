      "Edit(/etc/shadow)",
      "Edit(/etc/group)",
      "Edit(/etc/gshadow)",
      "Edit(/etc/sudoers)",
      "Edit(/etc/sudoers.d/**)",
      "Write(/)",
      "Write(/bin/**)",
      "Write(/boot/**)",
      "Write(/dev/**)",
      "Write(/lib/**)",
      "Write(/lib64/**)",
      "Write(/media/**)",
      "Write(/mnt/**)",
      "Write(/opt/**)",
      "Write(/proc/**)",
      "Write(/root/**)",
      "Write(/run/**)",
      "Write(/sbin/**)",
      "Write(/srv/**)",
      "Write(/sys/**)",
      "Write(/usr/**)",
      "Write(/nix/**)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "teammateMode": "auto"
