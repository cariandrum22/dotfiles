#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat >&2 <<'EOF'
Usage:
  mcp-with-credentials --server <server-name> [--config-dir <dir>] -- <command> [args...]

Description:
  Loads per-server credential files from:
    $XDG_CONFIG_HOME/claudius/credentials/mcp/<server-name>/
  (or $HOME/.config/claudius/... when XDG_CONFIG_HOME is unset),
  then exports each file as an environment variable where:
    VAR_NAME = basename(file)
    VAR_VALUE = file contents

Notes:
  - Files starting with '.' and '.gitkeep' are ignored.
  - This tool is intended to keep secrets out of tracked mcpServers.json by storing them
    under the git-ignored credentials/ directory.
EOF
}

server_name=""
config_dir=""

while [ $# -gt 0 ]; do
    case "$1" in
        --server)
            server_name="${2:-}"
            shift 2
            ;;
        --config-dir)
            config_dir="${2:-}"
            shift 2
            ;;
        --)
            shift
            break
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage
            exit 2
            ;;
    esac
done

if [ -z "$server_name" ]; then
    echo "Missing required argument: --server <server-name>" >&2
    usage
    exit 2
fi

if [ $# -lt 1 ]; then
    echo "Missing command after '--'" >&2
    usage
    exit 2
fi

if [ -z "$config_dir" ]; then
    config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
    config_dir="$config_home/claudius"
fi

credentials_dir="$config_dir/credentials/mcp/$server_name"
if [ ! -d "$credentials_dir" ]; then
    echo "Credentials directory not found: $credentials_dir" >&2
    exit 1
fi

shopt -s nullglob
for credential_file in "$credentials_dir"/*; do
    file_name="$(basename "$credential_file")"

    if [ "$file_name" = ".gitkeep" ]; then
        continue
    fi

    case "$file_name" in
        .* )
            continue
            ;;
    esac

    if [ ! -f "$credential_file" ]; then
        continue
    fi

    # Command substitution strips trailing newlines. This is desirable for typical token files.
    value="$(cat "$credential_file")"

    # Optional 1Password resolution: allow storing only an op:// reference in the credential file.
    # This keeps secrets out of plaintext at rest, at the cost of requiring a signed-in `op` session.
    if [[ "$value" == op://* ]]; then
        if ! command -v op >/dev/null 2>&1; then
            echo "1Password CLI ('op') is required to resolve $credentials_dir/$file_name" >&2
            exit 1
        fi

        if ! value="$(op read "$value")"; then
            echo "Failed to resolve 1Password reference for $credentials_dir/$file_name" >&2
            exit 1
        fi
    fi

    export "$file_name"="$value"
done

exec "$@"
